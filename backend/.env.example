# CampTrack Backend Environment Variables
# Copy file ini menjadi .env dan sesuaikan nilainya

# Database PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/camptrack_db"

# Server Port
PORT=3000

# WebSocket Port
WS_PORT=3001

# Environment (development / production)
NODE_ENV=development

# JWT Secret Key (ganti dengan string random yang panjang untuk production)
JWT_SECRET=camptrack_jwt_secret_key_production_2024
